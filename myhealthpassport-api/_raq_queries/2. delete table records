WITH RankedRecords AS (
    SELECT
        id,
        ROW_NUMBER() OVER(
            PARTITION BY student_id, report_type
            ORDER BY created_at DESC
        ) as rn
    FROM clinical_recomendations
)
DELETE FROM clinical_recomendations
WHERE id IN (
    SELECT id
    FROM RankedRecords
    WHERE rn > 1
);